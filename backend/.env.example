# Copy this file to .env and fill in your real values. Never commit the real .env.

# Get a free key at https://console.groq.com -> API Keys -> Create API Key
GROQ_API_KEY=gsk_your_real_key_here

# Easiest to start: SQLite, zero setup
DATABASE_URL=sqlite:///./complaints.db

# Once Postgres is installed (see README), switch to something like:
# DATABASE_URL=postgresql+psycopg2://complaint_user:complaint_pass@localhost:5432/complaint_db

# Comma-separated list of allowed frontend origins (CORS).
# In production (Render), set this to your deployed frontend's URL.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
